{
  "name": "opencode-iterm2-signals",
  "version": "0.2.0",
  "description": "Ambient iTerm2 background colors for OpenCode session states.",
  "type": "module",
  "main": "./src/plugin.js",
  "exports": {
    ".": "./src/plugin.js",
    "./cli": "./src/cli.js"
  },
  "bin": {
    "opencode-iterm2-signals": "src/cli.js"
  },
  "files": [
    "src",
    "README.md",
    "LICENSE",
    ".gitignore"
  ],
  "scripts": {
    "check": "node --check src/plugin.js && node --check src/cli.js",
    "doctor": "node src/cli.js doctor",
    "install:global": "node src/cli.js install",
    "preview": "node src/cli.js preview",
    "package:check": "npm pack --dry-run"
  },
  "keywords": [
    "opencode",
    "opencode-plugin",
    "iterm2",
    "macos",
    "ambient",
    "status"
  ],
  "author": "guard22",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/guard22/opencode-iterm2-signals.git"
  },
  "homepage": "https://github.com/guard22/opencode-iterm2-signals#readme",
  "bugs": {
    "url": "https://github.com/guard22/opencode-iterm2-signals/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  }
}
